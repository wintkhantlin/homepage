---
import { Image } from "astro:assets";

import photo1 from "../../assets/img/about/1.png";
import photo2 from "../../assets/img/about/2.png";
import photo3 from "../../assets/img/about/3.png";
import photo4 from "../../assets/img/about/4.png";

const photos = [
  { src: photo1, alt: "Wint Khant Lin — photo 1", tilt: "rotate-[2deg]" },
  { src: photo2, alt: "Wint Khant Lin — photo 2", tilt: "-rotate-[1.5deg]" },
  { src: photo3, alt: "Wint Khant Lin — photo 3", tilt: "rotate-[1deg]" },
  { src: photo4, alt: "Wint Khant Lin — photo 4", tilt: "-rotate-[2deg]" },
];

const tools = [
  {
    category: "Languages",
    items: ["TypeScript", "JavaScript", "Python", "Go"],
  },
  {
    category: "Backend",
    items: ["Node.js", "NestJS", "Express.js", "REST APIs"],
  },
  { category: "Frontend", items: ["Vue.js", "React", "Astro", "TailwindCSS"] },
  { category: "Data", items: ["PostgreSQL", "MongoDB", "Redis"] },
  { category: "Infra", items: ["Docker", "Git", "Linux", "Microservices"] },
];
---

<section id="about" class="mt-20 mb-16 pt-6">
  <div class="mx-auto max-w-4xl">
    <!-- Header -->
    <div class="mb-10">
      <h2
        class="max-w-3xl text-4xl font-medium leading-tight tracking-[-0.02em] text-(--text-heading) md:text-5xl"
      >
        A curious builder from Myanmar.
      </h2>
    </div>

    <!-- Photo collage -->
    <div class="mt-10 mb-12">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {
          photos.map((photo) => (
            <div
              class={`overflow-hidden transition-transform duration-300 hover:rotate-0 hover:scale-[1.03] ${photo.tilt}`}
            >
              <Image
                src={photo.src}
                alt={photo.alt}
                width={300}
                height={400}
                class="h-full w-full object-cover"
              />
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bio -->
    <div class="mb-14 space-y-5">
      <p class="text-[15px] leading-7 text-(--text-muted)">
        Hey, I'm <strong class="text-(--text-heading)">Wint Khant Lin</strong>,
        also known as <strong class="text-(--text-heading)">Happer</strong>. I'm
        a college student from Myanmar who's deeply passionate about software
        engineering — especially backend systems, distributed architectures, and
        building tools that solve real problems.
      </p>

      <p class="text-[15px] leading-7 text-(--text-muted)">
        I started coding because I was curious about how things work under the
        hood. That curiosity turned into a love for over-engineering side
        projects, exploring system design, and learning in public. Every project
        I ship teaches me something new.
      </p>

      <p class="text-[15px] leading-7 text-(--text-muted)">
        When I'm not coding, I'm probably listening to music, reading about
        software architecture, or planning my next experiment. I believe in the
        power of documenting the journey — sharing the process, not just the
        results.
      </p>

      <p class="text-[15px] leading-7 text-(--text-muted)">
        I'm always open to connecting with fellow developers, collaborating on
        interesting projects, or just having a conversation about tech. Feel
        free to reach out.
      </p>
    </div>

    <!-- Tools & Technologies -->
    <div class="mb-14">
      <h2 class="mb-6 text-lg font-semibold text-(--text-heading)">
        Tools & Technologies
      </h2>

      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-5">
        {
          tools.map((group) => (
            <div>
              <h3 class="mb-2.5 text-[10px] font-bold uppercase tracking-[0.2em] text-(--text-faint)">
                {group.category}
              </h3>
              <ul class="space-y-1.5">
                {group.items.map((item) => (
                  <li class="text-sm text-(--text-muted)">{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Contact CTA -->
    <div class="mb-8 rounded-2xl border border-(--border) p-8 text-center">
      <h2 class="text-xl font-semibold text-(--text-heading)">Let's connect</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-(--text-muted)">
        Whether you want to chat about tech, collaborate on a project, or just
        say hi — my inbox is always open.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a
          href="mailto:hello@wintkhantlin.com"
          class="inline-flex items-center gap-1.5 rounded-full border border-(--border) px-5 py-2.5 text-sm font-medium text-(--text-heading) transition-all duration-200 hover:border-(--text-faint) hover:bg-white/5"
        >
          Send an email
        </a>
        <a
          href="https://github.com/wintkhantlin"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-(--border) px-5 py-2.5 text-sm text-(--text-muted) transition-all duration-200 hover:border-(--text-faint) hover:text-(--text-heading)"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/wintkhantlin/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-(--border) px-5 py-2.5 text-sm text-(--text-muted) transition-all duration-200 hover:border-(--text-faint) hover:text-(--text-heading)"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
