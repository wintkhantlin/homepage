---
import { Icon } from "astro-icon/components";

type Post = Awaited<ReturnType<typeof import("../lib/content").getSortedPosts>>[number];

interface Props {
  post: Post;
  headingLevel?: "h2" | "h3";
  showExtraMeta?: boolean;
}

const { post, headingLevel = "h3", showExtraMeta = false } = Astro.props;

const wordCount = post.body?.split(/\s+/u).filter(Boolean).length ?? 0;
const minutes = showExtraMeta 
  ? Math.max(1, Math.ceil(wordCount / 180))
  : 0;
const isMyanmar = showExtraMeta 
  ? /[\u1000-\u109F]/u.test(post.data.title)
  : false;

const HeadingTag = headingLevel;
---

<a
  href={`/post/${post.id}`}
  class="invert-on-hover group flex flex-col justify-between border-b border-(--border) py-8 px-4 no-underline transition-colors sm:flex-row sm:items-center"
>
  <div class="flex min-w-0 flex-col gap-2 sm:w-2/3">
    <div class="flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-[0.15em] opacity-60">
      <span>{post.data.categories}</span>
      {isMyanmar && <span class="rounded-full border border-(--border) px-2 py-0.5 text-[10px]">Myanmar</span>}
    </div>
    <HeadingTag class="truncate text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl">
      {post.data.title}
    </HeadingTag>
  </div>

  <div class="mt-6 flex items-center justify-between sm:mt-0 sm:w-1/3 sm:justify-end sm:gap-12">
    <div class="flex flex-col items-end gap-1">
      <span class="font-mono text-xs opacity-60">
        {post.data.publishedDate.toLocaleDateString("en-US", {
          month: "short",
          day: "2-digit",
          year: "numeric",
        })}
      </span>
      {showExtraMeta && <span class="font-mono text-[10px] opacity-40">{minutes} min read</span>}
    </div>
    <div class="flex size-10 items-center justify-center rounded-full border border-(--border) transition-all duration-300">
      <Icon name="lucide:arrow-up-right" class="size-4 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
    </div>
  </div>
</a>
