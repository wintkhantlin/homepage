---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("content");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description ?? ""}>
  <main class="mx-auto my-20 max-w-4xl px-5 sm:px-6 md:px-8">
    <!-- Back -->
    <div class="mb-10 mt-10">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-(--text-muted) transition-opacity hover:opacity-60"
      >
        <span class="text-base leading-none">&lsaquo;</span>
        <span>Back</span>
      </a>
    </div>

    <!-- Header -->
    <section class="mb-12 border-b border-(--border) pb-10">
      <div class="mb-4 flex items-center gap-3">
        <span class="text-[10px] font-medium uppercase tracking-widest text-(--text-muted)">
          {post.data.categories}
        </span>

        <span class="text-xs text-(--text-faint)">·</span>

        <time class="font-mono text-[11px] text-(--text-muted)">
          {
            post.data.publishedDate.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </time>
      </div>

      <h1 class="max-w-3xl text-3xl font-medium leading-tight tracking-[-0.02em] text-(--text-heading) md:text-4xl">
        {post.data.title}
      </h1>

      {
        post.data.description && (
          <p class="mt-4 max-w-2xl text-[15px] leading-7 text-(--text-muted)">
            {post.data.description}
          </p>
        )
      }
    </section>

    <!-- Body -->
    <article
      class="prose mb-24 max-w-[68ch]
      prose-p:mb-6 prose-p:leading-7 prose-p:text-(--text-muted)

      prose-headings:font-medium
      prose-headings:tracking-[-0.02em]
      prose-h2:mb-3 prose-h2:mt-10 prose-h2:text-(--text-heading)
      prose-h3:mb-2 prose-h3:mt-8 prose-h3:text-(--text-heading)

      prose-strong:text-(--text-heading)

      prose-a:text-(--text-heading)
      prose-a:underline
      prose-a:decoration-(--border)
      prose-a:underline-offset-[3px]
      hover:prose-a:decoration-(--text-heading)

      prose-ul:text-(--text-muted)
      prose-ol:text-(--text-muted)
      prose-li:my-1

      prose-blockquote:border-l-2
      prose-blockquote:border-(--border)
      prose-blockquote:pl-4
      prose-blockquote:italic
      prose-blockquote:text-(--text-muted)

      prose-img:rounded-xl
      prose-img:border
      prose-img:border-(--border)

      prose-th:text-(--text-heading)
      prose-td:text-(--text-muted)

      prose-code:rounded-md
      prose-code:px-1.5
      prose-code:py-0.5
      prose-code:text-[0.9em]
      prose-code:font-medium
      prose-code:text-(--text-heading)

      prose-code:before:content-none
      prose-code:after:content-none

      prose-pre:overflow-x-auto
      prose-pre:rounded-2xl
      prose-pre:border
      prose-pre:border-white/5
      prose-pre:bg-[#1e252f]
      prose-pre:px-6
      prose-pre:py-5
      prose-pre:shadow-[inset_0_1px_0_rgba(255,255,255,0.03)]

      prose-pre:code:bg-transparent
      prose-pre:code:p-0
      prose-pre:code:text-[15px]
      prose-pre:code:leading-8
      prose-pre:code:font-normal
      prose-pre:code:text-[#e5e7eb]"
    >
      <Content />
    </article>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const links = document.querySelectorAll(".prose a");

      links.forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;

        const isInternal =
          href.startsWith("/") ||
          href.startsWith("#") ||
          href.startsWith("./");

        if (isInternal) return;

        try {
          const url = new URL(href, window.location.origin);

          if (url.origin !== window.location.origin) {
            link.setAttribute("target", "_blank");
            link.setAttribute("rel", "noopener noreferrer");
          }
        } catch {}
      });
    });
  </script>
</BaseLayout>