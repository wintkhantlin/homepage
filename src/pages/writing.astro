---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSortedPosts } from "../lib/content";
import PostCard from "../components/PostCard.astro";

const posts = await getSortedPosts();
---

<BaseLayout
  title="Writing | Wint Khant Lin"
  description="Notes and writing by Wint Khant Lin on software, systems, and learning in public."
>
  <main class="mx-auto max-w-5xl px-5 pb-16 pt-28 text-(--text) sm:px-6 md:px-8">
    <section class="flex flex-col border-t border-(--border)">
      {
        posts.map((post) => (
          <PostCard post={post} headingLevel="h2" showExtraMeta={true} />
        ))
      }
    </section>
  </main>
</BaseLayout>
