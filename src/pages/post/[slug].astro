---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("content");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description ?? ""}>
  <main class="mx-auto max-w-4xl px-5 sm:px-6 md:px-8 my-20">
    <!-- Back -->
    <div class="mt-10 mb-10">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm
      text-(--text-muted) no-underline transition-opacity hover:opacity-60"
      >
        <span class="text-base leading-none">&lsaquo;</span>
        <span>Back</span>
      </a>
    </div>

    <!-- Header -->
    <section class="mb-12 border-b border-(--border) pb-10">
      <div class="mb-4 flex items-center gap-3">
        <span
          class="text-[10px] uppercase tracking-widest font-medium text-(--text-muted)"
        >
          {post.data.categories}
        </span>
        <span class="text-(--text-faint) text-xs">·</span>
        <time class="font-mono text-[11px] text-(--text-muted)">
          {
            post.data.publishedDate.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </time>
      </div>

      <h1
        class="max-w-3xl text-3xl font-medium leading-tight tracking-[-0.02em] text-(--text-heading) md:text-4xl"
      >
        {post.data.title}
      </h1>

      {
        post.data.description && (
          <p class="mt-4 max-w-2xl text-[15px] leading-7 text-(--text-muted)">
            {post.data.description}
          </p>
        )
      }
    </section>

    <!-- Body -->
    <article class="prose-custom mb-24">
      <Content />
    </article>
  </main>

  <style>
    /* Prose styles scoped to this page, matching your design tokens */
    .prose-custom {
      max-width: 68ch;
      font-size: 15px;
      line-height: 1.85;
      color: var(--text);
    }

    .prose-custom :global(h2) {
      font-size: 1.15rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--text-heading);
      margin: 2.5rem 0 0.75rem;
    }

    .prose-custom :global(h3) {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-heading);
      margin: 2rem 0 0.5rem;
    }

    .prose-custom :global(p) {
      margin: 0 0 1.4rem;
    }

    .prose-custom :global(a) {
      color: var(--text-heading);
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      text-decoration-color: var(--border);
      transition: text-decoration-color 0.15s;
    }

    .prose-custom :global(a:hover) {
      text-decoration-color: var(--text-heading);
    }

    .prose-custom :global(code) {
      font-family: var(--font-mono, monospace);
      font-size: 0.82em;
      background: var(--border);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      color: var(--text-heading);
    }

    .prose-custom :global(pre) {
      background: var(--text-heading);
      color: var(--bg, #fff);
      padding: 1.25rem 1.5rem;
      border-radius: 6px;
      overflow-x: auto;
      font-size: 0.82em;
      line-height: 1.7;
      margin: 1.75rem 0;
    }

    .prose-custom :global(pre code) {
      background: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .prose-custom :global(blockquote) {
      border-left: 2px solid var(--border);
      margin: 1.75rem 0;
      padding: 0.25rem 0 0.25rem 1.25rem;
      color: var(--text-muted);
      font-style: italic;
    }

    .prose-custom :global(ul),
    .prose-custom :global(ol) {
      padding-left: 1.25rem;
      margin: 0 0 1.4rem;
    }

    .prose-custom :global(li) {
      margin-bottom: 0.4rem;
    }

    .prose-custom :global(hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    .prose-custom :global(img) {
      width: 100%;
      border-radius: 6px;
      border: 1px solid var(--border);
      margin: 1.75rem 0;
    }

    .prose-custom :global(table) {
      width: 100%;
      font-size: 0.9em;
      border-collapse: collapse;
      margin: 1.75rem 0;
    }

    .prose-custom :global(th) {
      text-align: left;
      font-weight: 500;
      color: var(--text-heading);
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
    }

    .prose-custom :global(td) {
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      color: var(--text-muted);
    }
  </style>
</BaseLayout>
