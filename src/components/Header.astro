---
import { Icon } from "astro-icon/components";

const links = [{ label: "Projects", href: "/#projects" }];
---

<header class="fixed inset-x-0 top-0 z-50 backdrop-blur-lg">
  <div class="mx-auto max-w-4xl px-5 sm:px-6 md:px-8">
    <div class="flex items-center justify-between py-5">
      <a
        href="/"
        class="text-sm font-semibold tracking-[0.025em] text-(--text-heading) transition-colors duration-150 hover:text-(--text)"
      >
        Wint Khant
      </a>

      <nav class="flex items-center gap-5 sm:gap-6">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm text-(--text-muted) transition-colors duration-150 hover:text-(--text-heading)"
            >
              {link.label}
            </a>
          ))
        }

        <a
          href="https://github.com/wintkhantlin"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-(--text-muted) transition-colors duration-150 hover:text-(--text-heading)"
        >
          GitHub
        </a>

        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="inline-flex items-center justify-center rounded-md size-8 text-sm text-(--text-muted) hover:bg-(--border) hover:text-(--text-heading) cursor-pointer transition-colors duration-200"
        >
          <span id="theme-icon-dark" class="hidden">
            <Icon name="lucide:sun" />
          </span>
          <span id="theme-icon-light" class="hidden">
            <Icon name="lucide:moon" />
          </span>
        </button>
      </nav>
    </div>
  </div>
</header>

<script>
  function updateIcons() {
    const isLight = document.documentElement.classList.contains("light");
    const darkIcon = document.getElementById("theme-icon-dark");
    const lightIcon = document.getElementById("theme-icon-light");

    if (darkIcon) darkIcon.classList.toggle("hidden", !isLight);
    if (lightIcon) lightIcon.classList.toggle("hidden", isLight);
  }

  function toggleTheme(e: MouseEvent) {
    const isLight = document.documentElement.classList.contains("light");
    const newTheme = isLight ? "dark" : "light";

    const x = e.clientX;
    const y = e.clientY;

    document.documentElement.style.setProperty("--x", `${x}px`);
    document.documentElement.style.setProperty("--y", `${y}px`);

    if (document.startViewTransition) {
      document.startViewTransition(() => {
        document.documentElement.classList.toggle(
          "light",
          newTheme === "light",
        );
        localStorage.setItem("theme", newTheme);
        updateIcons();
      });
    } else {
      document.documentElement.classList.toggle("light", newTheme === "light");
      localStorage.setItem("theme", newTheme);
      updateIcons();
    }
  }

  updateIcons();

  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", (e) => toggleTheme(e as MouseEvent));
</script>
