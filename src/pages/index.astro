---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const rawProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);

const posts = (await getCollection("content")).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);

const projects = await Promise.all(
  rawProjects.map(async (project) => {
    const [preview, blurPreview] = await Promise.all([
      getImage({
        src: project.data.img,
        width: 512,
        format: "webp",
      }),
      getImage({
        src: project.data.img,
        width: 24,
        format: "webp",
      }),
    ]);

    return {
      ...project,
      previewSrc: preview.src,
      blurPreviewSrc: blurPreview.src,
    };
  }),
);

const noteTilts = [
  "-rotate-[1.5deg]",
  "-rotate-[1.2deg]",
  "rotate-[0.8deg]",
  "-rotate-[0.5deg]",
  "rotate-[1.4deg]",
];

const noteColors = [
  "bg-yellow-50",
  "bg-pink-50",
  "bg-green-50",
  "bg-blue-50",
  "bg-orange-50",
];
---

<BaseLayout
  title="Wint Khant Lin aka Happer"
  description="Hello, I am Wint Khant Lin, also known as Happer. I am a college student from Myanmar. I love coding, listening to music."
>
  <main class="mx-auto max-w-4xl px-5 text-(--text) sm:px-6 md:px-8">
    <section class="mt-26">
      <p class="mb-3 text-sm text-(--text-muted)">Wint Khant Lin / Happer</p>

      <h1 class="max-w-3xl text-4xl font-medium leading-tight tracking-[-0.02em] text-(--text-heading) md:text-5xl">
        Curious about systems, software, and everything in between.
      </h1>

      <p class="mt-4 max-w-2xl text-[15px] leading-7 text-(--text-muted)">
        I’m a college student from Myanmar who enjoys building things, learning
        how software works, and exploring ideas across backend engineering,
        systems, and product development.
      </p>
    </section>

    <section
      id="projects"
      class="relative mt-12 mb-16 border-t border-(--border) pt-6"
    >
      <h2 class="mb-3 text-lg font-semibold text-(--text-heading)">
        Product Level Projects
      </h2>

      <p class="mb-4 max-w-2xl text-sm leading-6 text-(--text-muted)">
        A selection of things I’ve built and experimented with.
      </p>

      <div
        id="project-preview"
        class="pointer-events-none fixed top-0 left-0 z-50 hidden opacity-0 transition-opacity duration-200 ease-out md:block"
      >
        <img
          id="project-preview-img"
          src=""
          alt=""
          class="w-64 rounded-lg border border-(--border) object-cover shadow-2xl transition-[filter,opacity] duration-300 ease-out"
        />
      </div>

      <div id="projects-list" class="flex flex-col">
        {
          projects.map((project) => (
            <a
              href={project.data.source}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between border-b border-(--border) py-3 no-underline transition-opacity duration-150 hover:opacity-80"
              data-img={project.previewSrc}
              data-blur-img={project.blurPreviewSrc}
              data-name={project.data.name}
            >
              <div class="flex min-w-0 items-center gap-2.5">
                <span class="shrink-0 text-sm text-(--text-faint)">
                  &rsaquo;
                </span>

                <span class="truncate text-[15px] text-(--text) transition-colors duration-150 group-hover:text-(--text-heading)">
                  {project.data.name}
                </span>
              </div>

              <div class="ml-4 flex shrink-0 items-center gap-4 sm:gap-6">
                <span class="hidden text-sm text-(--text-muted) sm:block">
                  {project.data.type || project.data.description}
                </span>

                <span class="text-sm tabular-nums text-(--text-muted)">
                  {project.data.publishedDate.getFullYear()}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section id="writing" class="mt-12 mb-16 border-t border-(--border) pt-6">
      <h2 class="mb-1 text-lg font-semibold text-(--text-heading)">
        Notes / Writing
      </h2>

      <p class="mb-6 text-sm text-(--text-muted)">
        Thoughts, experiments, and things I found interesting.
      </p>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-6">
        {
          posts.map((post, index) => (
            <a
              href={`/post/${post.id}`}
              class={`note-card group relative block cursor-pointer border-b-[3px] border-black/5 p-4 pb-5 no-underline transition-all duration-200 hover:z-10 hover:rotate-0 hover:scale-[1.04] hover:shadow-2xl ${noteTilts[index % noteTilts.length]} ${noteColors[index % noteColors.length]}`}
            >
              <span class="absolute -top-2 left-1/2 h-3.5 w-3.5 -translate-x-1/2 rounded-full bg-red-500 shadow-md" />

              <span class="pointer-events-none absolute inset-0 top-8 bg-[repeating-linear-gradient(transparent,transparent_23px,rgba(0,0,0,0.07)_23px,rgba(0,0,0,0.07)_24px)]" />

              <span class="relative text-[10px] font-medium uppercase tracking-widest text-black/40">
                {post.data.categories}
              </span>

              <p class="relative mt-1.5 mb-2 text-sm font-medium leading-snug text-black/80">
                {post.data.title}
              </p>

              <p class="relative font-mono text-[11px] text-black/40">
                {post.data.publishedDate.toLocaleDateString("en-US", {
                  month: "short",
                  year: "numeric",
                })}
              </p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const preview = document.getElementById("project-preview");
  const previewImg = document.getElementById("project-preview-img");
  const projectLinks = document.querySelectorAll("#projects-list a");

  if (preview instanceof HTMLDivElement && previewImg instanceof HTMLImageElement) {
    const offset = 24;
    let currentFullSrc = "";

    const showPreview = () => {
      preview.classList.remove("hidden");
      requestAnimationFrame(() => {
        preview.style.opacity = "1";
      });
    };

    const hidePreview = () => {
      preview.style.opacity = "0";

      const handleTransitionEnd = () => {
        if (preview.style.opacity === "0") {
          preview.classList.add("hidden");
        }

        preview.removeEventListener("transitionend", handleTransitionEnd);
      };

      preview.addEventListener("transitionend", handleTransitionEnd);
    };

    const movePreview = (x: number, y: number) => {
      preview.style.transform = `translate(${x + offset}px, ${y + offset}px)`;
    };

    const showBlurPreview = (src: string, alt: string) => {
      previewImg.src = src;
      previewImg.alt = alt;
      previewImg.classList.add("blur-md", "opacity-70");
      previewImg.classList.remove("blur-0", "opacity-100");
    };

    const showFullPreview = (src: string, alt: string) => {
      previewImg.src = src;
      previewImg.alt = alt;
      previewImg.classList.remove("blur-md", "opacity-70");
      previewImg.classList.add("blur-0", "opacity-100");
    };

    projectLinks.forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;

      link.addEventListener("mouseenter", () => {
        const blurSrc = link.dataset.blurImg;
        const fullSrc = link.dataset.img;
        const name = link.dataset.name || "";

        if (!blurSrc || !fullSrc) return;

        currentFullSrc = fullSrc;

        showBlurPreview(blurSrc, name);
        showPreview();

        const fullImage = new Image();
        fullImage.src = fullSrc;

        fullImage.onload = () => {
          if (currentFullSrc !== fullSrc) return;
          showFullPreview(fullSrc, name);
        };
      });

      link.addEventListener("mouseleave", hidePreview);

      link.addEventListener("mousemove", (event) => {
        movePreview(event.clientX, event.clientY);
      });
    });
  }
</script>