---
import { Icon } from "astro-icon/components";
import PostCard from "../PostCard.astro";

type Post = Awaited<
  ReturnType<typeof import("../../lib/content").getSortedPosts>
>[number];

interface Props {
  posts: Post[];
}

const { posts } = Astro.props as Props;
---

<section id="writing" class="mt-32 mb-16 pt-6">
  <div
    class="mb-12 flex items-center justify-between border-b border-(--border) pb-4"
  >
    <h2
      class="text-xs font-bold uppercase tracking-[0.2em] text-(--text-heading)"
    >
      Notes & Writing
    </h2>
    <a
      href="/writing"
      class="group flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-(--text-faint) transition-colors hover:text-(--text-heading)"
    >
      <span>View Archive</span>
      <Icon
        name="lucide:arrow-right"
        class="size-3 transition-transform duration-300 group-hover:translate-x-1"
      />
    </a>
  </div>

  <div class="flex flex-col">
    {
      posts.map((post) => (
        <PostCard post={post} headingLevel="h3" showExtraMeta={false} />
      ))
    }
  </div>
</section>
