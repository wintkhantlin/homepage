---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/home/HeroSection.astro";
import ProjectsSection from "../components/home/ProjectsSection.astro";
import WritingSection from "../components/home/WritingSection.astro";
import AboutSection from "../components/home/AboutSection.astro";
import { getProjectsWithPreviews, getSortedPosts } from "../lib/content";

const [projects, posts] = await Promise.all([
  getProjectsWithPreviews(),
  getSortedPosts(),
]);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Wint Khant Lin",
  "alternateName": "Happer",
  "url": "https://wintkhantlin.com",
  "jobTitle": "Software Engineer",
  "sameAs": [
    "https://github.com/wintkhantlin",
    "https://www.linkedin.com/in/wintkhantlin/"
  ]
};
---

<BaseLayout
  title="Wint Khant Lin aka Happer"
  description="Portfolio of Wint Khant Lin (Happer), a software engineering student from Myanmar sharing backend projects, systems thinking, web development experiments, and programming notes."
  structuredData={structuredData}
>
  <main class="mx-auto max-w-5xl px-5 text-(--text) sm:px-6 md:px-8">
    <HeroSection />
    <ProjectsSection projects={projects} />
    <WritingSection posts={posts} />
    <AboutSection />
  </main>
</BaseLayout>
