---
import { Icon } from "astro-icon/components";

const socials = [
  { label: "GitHub", href: "https://github.com/wintkhantlin" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/wintkhantlin/" },
  { label: "Email", href: "mailto:wintkhantlin@gmail.com" },
];
---

<footer class="mt-32 border-t border-(--border)">
  <a
    href="mailto:wintkhantlin@gmail.com"
    class="invert-on-hover group flex w-full flex-col items-center justify-center border-b border-(--border) py-32 text-center transition-colors"
  >
    <span class="mb-4 text-xs font-bold uppercase tracking-[0.3em] opacity-60">Ready to talk?</span>
    <h2 class="text-[12vw] font-black leading-none tracking-tighter sm:text-[10vw]">
      LET'S TALK
    </h2>
    <div class="mt-8 flex h-12 w-12 items-center justify-center border border-(--border) transition-transform duration-500 group-hover:scale-110">
      <Icon name="lucide:arrow-up-right" class="size-5" />
    </div>
  </a>

  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-5 py-12 sm:flex-row sm:px-6 md:px-8">
    <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-(--text-faint)">
      <span>&copy; {new Date().getFullYear()}</span>
      <span class="h-1 w-1 bg-(--text-faint)"></span>
      <span>Wint Khant Lin</span>
    </div>

    <div class="flex items-center gap-8">
      {
        socials.map((social) => (
          <a
            href={social.href}
            target={social.href.startsWith("mailto") ? undefined : "_blank"}
            rel={social.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
            class="group relative text-xs font-bold uppercase tracking-[0.15em] text-(--text-heading)"
          >
            <span class="relative z-10">{social.label}</span>
            <span class="absolute -bottom-1.5 left-0 h-px w-0 bg-(--text-heading) transition-all duration-300 group-hover:w-full" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
